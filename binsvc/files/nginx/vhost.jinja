{%- set names = " ".join(nginx["server_names"]) %}
{%- if nginx.get("ssl_cert") %}
server {
    listen 80;
    server_name {{ names }};
    location / {
        return 301 https://$host$request_uri;
    }
}
{%- endif %}

upstream {{ vhost_name }} {
    server {{ nginx["upstream"] }};
    keepalive 10;
}

server {
{%- if nginx.get("ssl_cert") %}
    listen 443 ssl;
    server_name {{ names }};

    ssl_certificate {{ nginx["ssl_cert"] }};
    ssl_certificate_key {{ nginx["ssl_key"] }};
{%- else %}
    listen 80;
    server_name {{ names }};
{%- endif %}

{%- if "auth_basic" in nginx %}
    auth_basic "Administrator's Area";
    auth_basic_user_file /etc/nginx/htpasswd/{{ vhost_name }};
{%- endif %}

    root /dev/null;
    charset UTF-8;
    autoindex off;

    access_log /var/log/nginx/{{ vhost_name }}.access.log;
    error_log /var/log/nginx/{{ vhost_name }}.error.log;

    client_max_body_size 25m;

    location / {
        proxy_pass http://{{ vhost_name }};
        proxy_set_header       Host             $host;
        proxy_set_header       X-Real-IP        $remote_addr;
        proxy_set_header       X-Forwarded-For  $proxy_add_x_forwarded_for;
        proxy_send_timeout     240;
        proxy_read_timeout     240;
        proxy_connect_timeout  240;
    }
}
